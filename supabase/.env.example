# Copy to `supabase/.env` (gitignored). Used by `supabase functions serve` for local runs.
# For production, set the same names in the Supabase Dashboard (Edge Functions → Secrets)
# or with: supabase secrets set KEY=value

# notify-order emails the seller (auth email) + guest; requires verified from-domain for real recipients.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@uanditechsolution.com
RESEND_FROM_ORDERS_EMAIL=orders@uanditechsolution.com
RESEND_FROM_BILLING_EMAIL=billing@uanditechsolution.com
RESEND_FROM_SUPPORT_EMAIL=support@uanditechsolution.com
RESEND_FROM_WELCOME_EMAIL=welcome@uanditechsolution.com
RESEND_FROM_SYSTEM_EMAIL=noreply@uanditechsolution.com

SUPABASE_SERVICE_ROLE_KEY=
PAYSTACK_SECRET_KEY=
ARKESEL_SMS_API_KEY=
ARKESEL_SMS_SENDER_ID=
ARKESEL_SMS_ENABLED=true

# Optional
PAYSTACK_STORE_CALLBACK_BASE_URL=
APP_BASE_URL=
PAYSTACK_CALLBACK_URL=
PAYSTACK_PLAN_CALLBACK_URL=

# Optional for scheduled function protection (recommended):
# notify-seller-subscription-renewal expects header `x-cron-secret` matching this value.
CRON_SECRET=
