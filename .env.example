# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Edge Function secrets (Supabase Dashboard → Project Settings → Edge Functions → Secrets)
# Do not put service-role keys in Vite .env — use Dashboard secrets for deployed functions.
#
# notify-order + paystack-init:
#   SUPABASE_URL            (often auto-injected)
#   SUPABASE_ANON_KEY       (often auto-injected)
#   SUPABASE_SERVICE_ROLE_KEY
#   RESEND_API_KEY
#   RESEND_FROM_EMAIL       (e.g. onboarding@resend.dev on Resend free tier)
#   WHATSAPP_CLOUD_TOKEN    (Meta permanent token)
#   WHATSAPP_PHONE_NUMBER_ID
#   PAYSTACK_SECRET_KEY     (sk_test_… for test mode)
#   PAYSTACK_SUBSCRIPTION_AMOUNT_PESEWAS  (optional, default 10000 = GHS 100.00)
#   PAYSTACK_CALLBACK_URL   (optional; after Paystack redirect)
#
# Super admin (after migration 20260418140000_super_admin_platform.sql):
#   insert into public.admin_roles (user_id) values ('<your-auth.users.id>');
