# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# --- Vite (this file / project root `.env`) ---
# Only `VITE_*` variables are exposed to the browser. Do not put secret keys here for “edge”
# use — the SPA never reads RESEND / Paystack secrets from root `.env`.

# --- Edge Functions (email, Paystack, SMS) ---
# Deployed: Supabase Dashboard → Project Settings → Edge Functions → Secrets, or:
#   supabase secrets set RESEND_API_KEY=re_... RESEND_FROM_EMAIL=you@yourdomain.com
#
# Local (`supabase functions serve`): copy `supabase/.env.example` → `supabase/.env` and fill in.
# The CLI loads `supabase/.env` automatically when that file exists.
#
# Deploy Edge Functions from this repo (CLI ships as a devDependency — use npm, not global `supabase`):
#   npm install
#   npm run functions:login
#   npm run functions:link -- --project-ref YOUR_PROJECT_REF
#   npm run functions:deploy
#
# `supabase/config.toml` sets `verify_jwt = true` per Edge Function (CLI requires per-function keys).
# If access tokens use ES256 and the gateway returns UNAUTHORIZED_UNSUPPORTED_TOKEN_ALGORITHM,
# see comments in that file (JWT settings or per-function verify_jwt = false with strong in-function auth).
#
# Store Paystack return URL (so Paystack redirects to /dashboard/stores/<storeId>?reference=…):
#   PAYSTACK_STORE_CALLBACK_BASE_URL=https://yourapp.com   (no path; edge builds …/dashboard/stores/<id>)
#   or APP_BASE_URL with the same meaning.
# Fallback if unset: PAYSTACK_CALLBACK_URL (must then be a full URL you maintain per environment).

# Edge Function secrets (Supabase Dashboard → Project Settings → Edge Functions → Secrets)
# Do not put service-role keys in Vite .env — use Dashboard secrets for deployed functions.
#
# notify-order + paystack-init:
#   SUPABASE_URL            (often auto-injected)
#   SUPABASE_ANON_KEY       (often auto-injected)
#   SUPABASE_SERVICE_ROLE_KEY
#   RESEND_API_KEY
#   RESEND_FROM_EMAIL         (global fallback sender)
#   RESEND_FROM_ORDERS_EMAIL  (orders + order status updates; recommended: orders@uanditechsolution.com)
#   RESEND_FROM_BILLING_EMAIL (subscription/payment mails; recommended: billing@uanditechsolution.com)
#   RESEND_FROM_SUPPORT_EMAIL (reserved for future support reply flow; recommended: support@uanditechsolution.com)
#   RESEND_FROM_WELCOME_EMAIL (reserved for future welcome flow; recommended: welcome@uanditechsolution.com)
#   RESEND_FROM_SYSTEM_EMAIL  (reserved for auth/system templates; recommended: noreply@uanditechsolution.com)
#   Any sender above must be from a verified domain in Resend.
#   CRON_SECRET               (recommended: shared secret for scheduled function calls, sent as x-cron-secret)
#   Order emails (notify-order): seller = store owner's Supabase Auth email; requires RESEND_* secrets on the project.
#   ARKESEL_SMS_API_KEY
#   ARKESEL_SMS_SENDER_ID   (approved sender name, optional depending on account)
#   ARKESEL_SMS_ENABLED     (optional; default true)
#   PAYSTACK_SECRET_KEY     (sk_test_… for test mode)
#   PAYSTACK_SUBSCRIPTION_AMOUNT_PESEWAS  (optional legacy: old store checkouts without plan_id in metadata;
#                                           new store fees use Starter/Growth/Pro amounts from paystack-init)
#   PAYSTACK_STORE_CALLBACK_BASE_URL  (recommended; origin only, for store subscription return)
#   APP_BASE_URL            (optional; same as PAYSTACK_STORE_CALLBACK_BASE_URL if you prefer one name)
#   PAYSTACK_CALLBACK_URL   (optional fallback; full URL if not using STORE_CALLBACK_BASE_URL)
#   PAYSTACK_PLAN_CALLBACK_URL  (optional; dashboard plan checkout — full URL to /dashboard,
#                                 e.g. https://yourapp.com/dashboard so Paystack returns with ?reference=)
#
# Super admin (after migration 20260418140000_super_admin_platform.sql):
#   insert into public.admin_roles (user_id) values ('<your-auth.users.id>');
